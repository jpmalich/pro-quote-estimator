# Pro-Quote backend configuration.
# Copy to backend/.env and fill in real values. The server FAILS CLOSED at
# startup if the required secrets below are missing or too weak.

# --- Database (required) ---------------------------------------------------
MONGO_URL=mongodb://localhost:27017
DB_NAME=proquote

# --- Auth (required) --------------------------------------------------------
# Generate: python -c 'import secrets; print(secrets.token_hex(32))'
JWT_SECRET=
# Seeded supplier-admin login
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
# Session/cookie lifetime in seconds (default 7 days)
#JWT_TTL_SECONDS=604800

# --- CORS (required — comma-separated allowlist, no wildcard) ---------------
CORS_ORIGINS=http://localhost:3000

# --- Supplier branding -------------------------------------------------------
SUPPLIER_NAME=Alside Supply
SUPPLIER_TAGLINE=
ADMIN_COMPANY=Pro-Quote Estimating Tool
# Token for the /branding-admin panel (sent as the X-Admin-Token header).
# Empty = every admin route is rejected.
SUPPLIER_ADMIN_TOKEN=
# Contractor access code for new-company signup. If unset, a stable code is
# derived from JWT_SECRET.
SIGNUP_CODE=

# --- AI measurement (required for AI Measure / Blueprint / HOVER import) ----
# Direct Anthropic API key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# Max output tokens per LLM call (default 16384)
#LLM_MAX_TOKENS=16384

# --- Email via Resend (optional — quote sending disabled if unset) -----------
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev
# Svix signing secret for the Resend delivery/open/click webhook
RESEND_WEBHOOK_SECRET=

# --- Satellite measure (optional) --------------------------------------------
GOOGLE_MAPS_API_KEY=

# --- Feature flags ------------------------------------------------------------
# Truthy = use the new per-profile LP SmartSide quantity formulas
#LP_AI_FORMULAS_V1=1
